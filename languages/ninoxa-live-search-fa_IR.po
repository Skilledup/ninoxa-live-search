#. Description of the plugin
#: ninoxa-live-search.php
msgid "A plugin to add live search functionality to your WordPress site."
msgstr "افزودن امکان جستجو زنده به وردپرس."

#. Author of the plugin
#: ninoxa-live-search.php
msgid "Mohammad Anbarestany"
msgstr "محمد عنبرستانی"

#: includes/class-ninoxa-live-search-search.php:134
#: includes/class-ninoxa-live-search-search.php:191
msgid "no results found..."
msgstr "نتیجه‌ای یافت نشد..."

#: includes/class-ninoxa-live-search-search.php:184
msgid "More results..."
msgstr "نتایج بیشتر..."

#: includes/class-ninoxa-live-search-search.php:111
msgid "Missing nonce"
msgstr "توکن امنیتی موجود نیست"

#: includes/class-ninoxa-live-search-search.php:123
msgid "Invalid nonce"
msgstr "توکن امنیتی نامعتبر"

#: includes/class-ninoxa-live-search-assets.php:54
msgid "Search suggestions"
msgstr "پیشنهادات جستجو"

#: includes/class-ninoxa-live-search-assets.php:55
msgid "1 suggestion available"
msgstr "۱ پیشنهاد موجود است"

#. translators: %d is the number of suggestions available.
#: includes/class-ninoxa-live-search-assets.php:57
#, php-format
msgid "%d suggestions available"
msgstr "%d پیشنهاد موجود است"

#: includes/class-ninoxa-live-search-assets.php:58
msgid "Search temporarily unavailable. Please try again."
msgstr "جستجو موقتاً در دسترس نیست. لطفاً دوباره تلاش کنید."

#: includes/class-ninoxa-live-search-assets.php:59
msgid "Search security token refresh failed"
msgstr "بروزرسانی توکن امنیتی جستجو ناموفق"

#: includes/class-ninoxa-live-search-assets.php:60
msgid "Search request failed"
msgstr "درخواست جستجو ناموفق"

#. Plugin Name of the plugin
#: ninoxa-live-search.php includes/class-ninoxa-live-search-settings.php:48
#: includes/class-ninoxa-live-search-settings.php:153
msgid "Ninoxa Live Search"
msgstr "جستجوی زنده نینوکسا"

#. Author URI of the plugin
#: ninoxa-live-search.php
msgid "https://profiles.wordpress.org/macse2/"
msgstr "https://profiles.wordpress.org/macse2/"

#. translators: 1: result index number, 2: post title.
#: includes/class-ninoxa-live-search-search.php:161
#, php-format
msgid "Search result %1$d: %2$s"
msgstr "نتایج جستجو %1$d: %2$s"

#. translators: %s is the search query.
#: includes/class-ninoxa-live-search-search.php:178
#, php-format
msgid "View more search results for: %s"
msgstr "دیدن نتایج بیشتر برای: %s"

#. Plugin URI of the plugin
#: ninoxa-live-search.php
msgid "https://wordpress.org/plugins/ninoxa-live-search/"
msgstr "https://wordpress.org/plugins/ninoxa-live-search/"

#: includes/class-ninoxa-live-search-settings.php:49
msgid "Ninoxa"
msgstr "نینوکسا"

#: includes/class-ninoxa-live-search-settings.php:124
#: includes/class-ninoxa-live-search-settings.php:255
#: includes/class-ninoxa-live-search-settings.php:260
msgid "Disabled"
msgstr "غیرفعال"

#: includes/class-ninoxa-live-search-settings.php:125
msgid "Focus the field and press the shortcut you want to use."
msgstr "روی فیلد کلیک کنید و ترکیب کلید های مورد نظرتان رو فشار دهید."

#: includes/class-ninoxa-live-search-settings.php:126
msgid "Listening for your shortcut."
msgstr "در انتظار فشردن کلید ها."

#: includes/class-ninoxa-live-search-settings.php:127
msgid "Shortcut captured. Save settings to apply it."
msgstr "میان‌ بر دریافت شد. لطفاً تنظیمات را ذخیره کنید."

#: includes/class-ninoxa-live-search-settings.php:128
msgid "Shortcut cleared. Save settings to keep it disabled."
msgstr "میان بر حذف شد. تنظیمات را ذخیره کنید تا میان بر غیرفعال شود."

#: includes/class-ninoxa-live-search-settings.php:129
msgid "Add one key besides Ctrl, Alt, Shift, or Cmd."
msgstr "بجز کنترل، شیفت، آلت یا کامند کلید دیگری را نیز فشار دهید."

#: includes/class-ninoxa-live-search-settings.php:130
#: includes/class-ninoxa-live-search-settings.php:316
msgid "Keyboard shortcut must contain one key and optional modifiers like Ctrl, Alt, Shift, or Cmd."
msgstr "میان‌بر صفحه کلید باید شامل یک کلید و تغییردهنده‌های اختیاری مانند Ctrl، Alt، Shift یا Cmd باشد."

#: includes/class-ninoxa-live-search-settings.php:156
msgid "AJAX-powered instant search results for your WordPress site."
msgstr "نتایج جستجوی فوری‌ای که توسط AJAX برای سایت وردپرس شما ارائه می‌شود."

#: includes/class-ninoxa-live-search-settings.php:169
msgid "Save settings"
msgstr "ذخیره تنظیمات"

#: includes/class-ninoxa-live-search-settings.php:227
msgid "Clear"
msgstr "حذف"

#: includes/class-ninoxa-live-search-settings.php:233
msgid "Focus the field and press the shortcut you want to use. Backspace or Delete clears it."
msgstr "روی فیلد کلیک کنید و میان‌بری که می‌خواهید استفاده کنید را فشار دهید. کلید Backspace یا Delete آن را حذف می‌کند."

#: includes/class-ninoxa-live-search-settings.php:259
msgid "Shown on search field"
msgstr "نمایش شده در فیلد جستجو"

#: includes/class-ninoxa-live-search-settings.php:333
msgid "General"
msgstr "عمومی"

#: includes/class-ninoxa-live-search-settings.php:334
msgid "Choose how visitors trigger and use live search."
msgstr "نحوه فعال‌سازی و استفاده از جستجوی زنده توسط بازدیدکنندگان را انتخاب کنید."

#: includes/class-ninoxa-live-search-settings.php:348
msgid "Keyboard shortcut"
msgstr "میان‌بر صفحه کلید"

#: includes/class-ninoxa-live-search-settings.php:350
msgid "Press keys"
msgstr "کلیدها را فشار دهید"

#: includes/class-ninoxa-live-search-settings.php:352
msgid "Allowed keys: letters (A–Z), digits (0–9), symbols (/ . , ; - = [ ] ' `), function keys (F1–F12), and named keys — Enter, Escape, Backspace, Delete, Tab, Space, Insert, Home, End, Page Up, Page Down, and arrows. Combine with Ctrl, Alt, Shift, or Cmd. Leave empty to disable the shortcut and its hint."
msgstr "کلیدهای مجاز: حروف (A–Z)، اعداد (0–9)، نمادها (/ . , ; - = [ ] ' `)، کلیدهای تابع (F1–F12)، و کلیدهای نام‌گذاری شده — Enter، Escape، Backspace، Delete، Tab، Space، Insert، Home، End، Page Up، Page Down، و کلیدهای جهتی. آن‌ها را با Ctrl، Alt، Shift یا Cmd ترکیب کنید. برای غیرفعال کردن میان‌بر و نکته آن، آن را خالی بگذارید."
